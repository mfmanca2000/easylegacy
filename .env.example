# ============================================================
# EasyLegacy — environment variables  (Section 7)
# Copy this file to .env (local dev) or configure in Coolify secrets.
# ============================================================

# ---------------------------------------------------------------------------
# Owner credentials — set once, no registration flow
# ---------------------------------------------------------------------------

# Owner username (optional — if set, both username AND password are checked)
OWNER_USERNAME=

# bcrypt hash of the owner's server password
# Generate: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
OWNER_PASSWORD_HASH=

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------

# 64 random hex chars used to sign/verify session tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# For docker-compose the host is "db" (service name); for Coolify use the internal hostname
DATABASE_URL=postgresql://easylegacy:changeme@db:5432/easylegacy

# PostgreSQL credentials (docker-compose only — Coolify manages these via env)
POSTGRES_USER=easylegacy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=easylegacy

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------

# Resend API key (https://resend.com — free tier: 3,000 emails/month)
# Alternatively set EMAIL_PROVIDER=smtp and fill SMTP_* vars (Week 8+)
RESEND_API_KEY=

# From address for notification emails
EMAIL_FROM=noreply@yourdomain.com

# ---------------------------------------------------------------------------
# Trust transfer
# ---------------------------------------------------------------------------

# Secret for the internal /api/trust/grant cron endpoint (Coolify scheduled job)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# 32 random hex chars — encrypts email addresses at rest in the trust_configs table.
# The server needs to decrypt these to send notification emails (Week 8+).
# NOT related to vault encryption — the server cannot decrypt vault content.
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SERVER_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# App URL (used in email links)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://arivederlestelle.org

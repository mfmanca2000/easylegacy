# ============================================================
# EasyLegacy — environment variables
# Copy this file to .env (local dev) or set in Coolify secrets
# ============================================================

# PostgreSQL connection string
# For docker-compose the host is "db" (service name)
DATABASE_URL="postgresql://easylegacy:changeme@db:5432/easylegacy"

# bcrypt hash of the owner's server password
# Generate with: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
OWNER_PASSWORD_HASH=""

# 32-byte random secret (unused in Week 1, reserved for future signing)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# PostgreSQL credentials — used by docker-compose only
POSTGRES_USER="easylegacy"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="easylegacy"

# Email (Resend) — used starting Week 2 (trust transfer notifications)
RESEND_API_KEY=""
OWNER_EMAIL=""
SPOUSE_EMAIL=""
